# LLM (OpenAI / GPT)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-chat-latest

# Materials Project (https://next-gen.materialsproject.org/api) - free signup
MP_API_KEY=

# Semantic Scholar - optional, raises rate limits (https://www.semanticscholar.org/product/api)
SEMANTIC_SCHOLAR_API_KEY=

# Vector store (local Chroma, free, no account needed)
CHROMA_PERSIST_DIR=./data/chroma
EMBEDDING_MODEL=BAAI/bge-m3

# Relational memory (SQLite by default, swap for postgresql:// in production)
DATABASE_URL=sqlite:///./data/materialgpt.db

# Knowledge graph (optional - Graph RAG node is a no-op if unset)
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

APP_ENV=development
